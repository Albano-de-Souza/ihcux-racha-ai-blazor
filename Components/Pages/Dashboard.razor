@page "/dashboard"
@using RachaAiBlazor.Models

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Olá, Albano 👋</h2>
        <button class="btn btn-primary rounded-pill px-4 shadow">Novo Gasto</button>
    </div>

    <div class="row g-3 mb-4 text-center">
        <div class="col-md-4">
            <div class="card bg-primary text-white p-3 border-0 shadow-sm">
                <small>Saldo Geral</small>
                <h3 class="fw-bold">R$ 798,60</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 border-0 shadow-sm border-start border-success border-4">
                <small class="text-muted">A Receber</small>
                <h3 class="text-success fw-bold">R$ 1.285,00</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 border-0 shadow-sm border-start border-danger border-4">
                <small class="text-muted">A Pagar</small>
                <h3 class="text-danger fw-bold">R$ 486,40</h3>
            </div>
        </div>
    </div>

    <div class="mb-4">
        <input type="text" class="form-control" placeholder="Buscar grupo ou categoria..." 
               @bind-value="searchTerm" @bind-value:event="oninput" />
    </div>

    <h6 class="text-muted fw-bold mb-3 text-uppercase" style="font-size: 0.8rem;">Seus Grupos Ativos</h6>

    @if (!FilteredGroups.Any())
    {
        <div class="alert alert-light border text-center py-4">
            <p class="mb-0 text-muted">Você ainda não participa de nenhum grupo. Que tal criar um?</p>
        </div>
    }
    else
    {
        @foreach (var g in FilteredGroups)
        {
            <GrupoCard Group="g" />
        }
    }
</div>

@code {
    private string searchTerm = "";
    private List<Grupo> grupos = new();

    protected override void OnInitialized()
    {
        // Lista estática conforme a imagem da Lista XVI
        grupos = new List<Grupo>
        {
            new Grupo { Nome = "República Central", Categoria = "Casa", ValorPendente = 450.50m, NoVermelho = true },
            new Grupo { Nome = "Churrasco de Domingo", Categoria = "Lazer", ValorPendente = 85.00m, NoVermelho = false },
            new Grupo { Nome = "Viagem Floripa", Categoria = "Viagem", ValorPendente = 1200.00m, NoVermelho = false },
            new Grupo { Nome = "Netflix & Internet", Categoria = "Contas", ValorPendente = 35.90m, NoVermelho = true }
        };
    }

    private IEnumerable<Grupo> FilteredGroups => 
        grupos.Where(g => string.IsNullOrWhiteSpace(searchTerm) || 
                     g.Nome.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                     g.Categoria.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
}